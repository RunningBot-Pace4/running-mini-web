DATABASE_URL="postgresql://postgres:postgres@localhost:5432/running_mini_web?schema=public"
APP_URL="http://localhost:3000"
SESSION_COOKIE_NAME="rmw_session"
APP_TIME_ZONE="Asia/Kuala_Lumpur"
EVENT_TIME_ZONE_OFFSET="+08:00"

# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID="your_strava_client_id"
STRAVA_CLIENT_SECRET="your_strava_client_secret"
STRAVA_REDIRECT_URI="http://localhost:3000/api/strava/callback"

# Used by `npm run seed`
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"

# Optional: password reset email provider. If empty, reset links are shown only for testing.
RESEND_API_KEY=""
RESEND_FROM="Run Mini <noreply@yourdomain.com>"
SHOW_RESET_LINK="false"

# Automatically close voting/submission this many hours after event end time
EVENT_AUTO_CLOSE_AFTER_HOURS=8
